.tab-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  display: flex;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.03);
  z-index: 999;
}
.tab-bar-border {
  background-color: rgba(0, 0, 0, 0.05);
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1px;
  transform: scaleY(0.5);
}
.tab-bar-item {
  flex: 1;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}
.tab-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 6rpx;
  transition: transform 0.2s;
}
.tab-bar-item:active .tab-icon {
  transform: scale(0.9);
}
.tab-text {
  font-size: 22rpx;
  font-weight: bold;
}