page { background-color: #f8fafc; }
.page-container { display: flex; flex-direction: column; padding-bottom: 120rpx; }

/* 搜索栏与导航区 */
.search-section { background-color: #ffffff; padding: 25rpx 30rpx; position: sticky; top: 0; z-index: 100; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02); }
.search-box { background-color: #f1f5f9; border-radius: 40rpx; height: 72rpx; display: flex; align-items: center; padding: 0 30rpx; }
.search-input { flex: 1; margin-left: 20rpx; font-size: 28rpx; color: #1e293b; }
.grid-section { padding: 30rpx; background-color: #f8fafc;}
.grid-card { background: #ffffff; border-radius: 32rpx; padding: 40rpx; display: flex; justify-content: space-between; box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.03); }
.grid-item { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; transition: all 0.3s; }
.grid-item.active { transform: scale(1.05); }
.grid-item.active text { color: #2563eb; font-weight: bold; }
.icon-circle { width: 110rpx; height: 110rpx; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 55rpx; margin-bottom: 20rpx; transition: all 0.3s; }
.grid-item.active .icon-circle { box-shadow: 0 8rpx 25rpx rgba(37,99,235,0.25); }
.bg-blue { background-color: #eff6ff; }
.bg-purple { background-color: #f5f3ff; }
.bg-green { background-color: #ecfdf5; }
.bg-red { background-color: #fef2f2; }
.grid-item text { font-size: 26rpx; color: #64748b; font-weight: 500;}
.main-content { padding: 0 30rpx 30rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0 30rpx;}
.main-title { font-size: 36rpx; font-weight: 800; color: #1e293b; }
.header-right { display: flex; align-items: center; }
.view-all { font-size: 26rpx; color: #94a3b8; margin-right: 20rpx; }
.publish-btn { font-size: 26rpx; color: #ffffff; background-color: #2563eb; padding: 12rpx 30rpx; border-radius: 30rpx; font-weight: bold; transition: background-color 0.2s;}
.publish-btn.purple-btn { background-color: #8b5cf6; }
.publish-btn.green-btn { background-color: #10b981; }

/* 1. 校园墙卡片 (Wall) */
.modern-card { background-color: #ffffff; border-radius: 28rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02); }
.card-user { display: flex; align-items: center; margin-bottom: 20rpx;}
.user-avatar-placeholder { width: 70rpx; height: 70rpx; background-color: #e2e8f0; border-radius: 50%; text-align: center; line-height: 70rpx; font-size: 35rpx; margin-right: 20rpx;}
.user-info { flex: 1; display: flex; flex-direction: column; }
.user-name { font-size: 28rpx; font-weight:bold; color: #1e293b; }
.user-time { font-size: 22rpx; color: #94a3b8; }
.card-content { margin-bottom: 25rpx;}
.content-text { font-size: 29rpx; line-height: 1.6; color: #334155; display: block;}
.content-img { width: 100%; border-radius: 16rpx; margin-top: 15rpx;}
.custom-tag { display: inline-block; color: #3b82f6; background-color: #eff6ff; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; margin-bottom: 15rpx; font-weight: bold; }

/* 2. 跑腿代拿卡片 (Errand) - 🚀 之前被弄丢的样式！ */
.task-card { background: #ffffff; border-radius: 24rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02); }
.task-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.task-user { display: flex; align-items: center; }
.tu-avatar { width: 60rpx; height: 60rpx; background: #f5f3ff; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 30rpx; margin-right: 15rpx; }
.tu-name { font-size: 28rpx; font-weight: bold; color: #1e293b; }
.task-price { color: #ef4444; font-size: 24rpx; font-weight: bold; }
.price-num { font-size: 44rpx; }
.task-title { font-size: 32rpx; font-weight: bold; color: #334155; line-height: 1.5; display: block; margin-bottom: 20rpx; }
.task-info-list { background: #f8fafc; border-radius: 12rpx; padding: 20rpx; margin-bottom: 25rpx; }
.ti-item { display: flex; align-items: center; font-size: 26rpx; color: #64748b; margin-bottom: 10rpx; }
.ti-item:last-child { margin-bottom: 0; }
.ti-icon { margin-right: 10rpx; }
.task-bot { display: flex; justify-content: space-between; align-items: center; border-top: 1rpx solid #f1f5f9; padding-top: 25rpx; }
.task-tags { display: flex; gap: 15rpx; }
.t-tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: bold; }
.t-tag.urgent { background: #fee2e2; color: #ef4444; }
.t-tag.type { background: #e0e7ff; color: #4f46e5; }
.task-btn { margin: 0; background: #3b82f6; color: #ffffff; font-size: 28rpx; padding: 12rpx 40rpx; border-radius: 40rpx; font-weight: bold; box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.3); }

/* 3. 闲置市场卡片 (Market) - 🚀 之前被弄丢的样式！ */
.market-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.m-card { width: 48%; background: #ffffff; border-radius: 20rpx; overflow: hidden; margin-bottom: 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02); display: flex; flex-direction: column;}
.m-img { width: 100%; height: 320rpx; background: #f1f5f9; }
.m-content-box { padding: 20rpx; display: flex; flex-direction: column; flex: 1; justify-content: space-between;}
.m-title { font-size: 28rpx; font-weight: bold; color: #334155; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 15rpx; line-height: 1.4; }
.m-tags { display: flex; gap: 10rpx; margin-bottom: 15rpx; flex-wrap: wrap;}
.m-tag { font-size: 20rpx; padding: 4rpx 10rpx; border-radius: 6rpx; }
.m-tag.trade { background: #dcfce7; color: #16a34a; }
.m-tag.condition { background: #f1f5f9; color: #64748b; }
.m-price-row { display: flex; align-items: baseline; margin-bottom: 15rpx; }
.m-price { color: #ef4444; font-size: 36rpx; font-weight: 900; margin-right: 10rpx; }
.m-symbol { font-size: 24rpx; }
.m-original-price { color: #94a3b8; font-size: 22rpx; text-decoration: line-through; }
.m-user-row { display: flex; justify-content: space-between; align-items: center; border-top: 1rpx dashed #f1f5f9; padding-top: 15rpx; }
.m-user { display: flex; align-items: center; max-width: 50%; }
.m-avatar { width: 36rpx; height: 36rpx; background: #e2e8f0; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 20rpx; margin-right: 10rpx; flex-shrink: 0; }
.m-name { font-size: 22rpx; color: #64748b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.m-action { display: flex; align-items: center; gap: 15rpx; }
.m-stat, .m-like { font-size: 22rpx; color: #94a3b8; display: flex; align-items: center; }
.m-like.liked { color: #ef4444; font-weight: bold; }

/* 4. 外卖卡片 (Food) */
.food-card { background: #fff; border-radius: 24rpx; padding: 25rpx; display: flex; margin-bottom: 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02); }
.food-img { width: 160rpx; height: 160rpx; border-radius: 16rpx; margin-right: 25rpx; background: #f1f5f9; flex-shrink: 0;}
.food-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.food-name-row { display: flex; justify-content: space-between; align-items: center; }
.food-name { font-size: 32rpx; font-weight: bold; color: #1e293b; }
.food-tag { font-size: 20rpx; color: #ef4444; background: #fee2e2; padding: 4rpx 12rpx; border-radius: 6rpx; }
.food-score { font-size: 26rpx; color: #f59e0b; font-weight: bold; margin-top: 10rpx; }
.sales { color: #94a3b8; font-size: 24rpx; font-weight: normal; margin-left: 15rpx; }
.food-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 15rpx; }
.food-price { font-size: 28rpx; color: #1e293b; font-weight: bold; }
.order-btn { margin: 0; background: #ef4444; color: #fff; font-size: 24rpx; padding: 10rpx 30rpx; border-radius: 30rpx; font-weight: bold; }

/* 🚀 底部互动与管理按钮区 (防挤压布局) */
.card-footer { border-top: 1rpx solid #f8fafc; padding-top: 25rpx; display: flex; flex-direction: row; justify-content: space-between; align-items: center; flex-wrap: nowrap; }
.interaction-box { display: flex; flex-direction: row; align-items: center; gap: 30rpx; }
.self-actions-box { display: flex; flex-direction: row; align-items: center; gap: 15rpx;}
.btn { font-size: 26rpx; color: #64748b; font-weight: 500; display: flex; align-items: center; gap: 8rpx; }
.btn.liked { color: #ef4444; font-weight: bold; }

/* 自己发布的专属管理按钮 */
.self-action { padding: 8rpx 20rpx; border-radius: 8rpx; font-size: 24rpx; margin-left: 0; }
.self-action.edit { color: #3b82f6; background: #eff6ff; }
.self-action.delete { color: #ef4444; background: #fee2e2; }

.pop-animation { animation: pop 0.3s ease-in-out; }
@keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }
.search-input-placeholder { flex: 1; margin-left: 20rpx; font-size: 28rpx; color: #94a3b8; }