page { background: #f8fafc; font-family: -apple-system; }
.page-container { padding-bottom: 60rpx; }

/* 搜索 */
.search-section { padding: 20rpx 30rpx; background: #fff; }
.search-box { background: #f1f5f9; height: 75rpx; border-radius: 38rpx; display: flex; align-items: center; padding: 0 30rpx; }
.search-input { margin-left: 15rpx; font-size: 26rpx; flex: 1; }

/* 导航 */
.grid-section { padding: 30rpx; }
.grid-card { background: #fff; border-radius: 32rpx; display: flex; padding: 35rpx 0; box-shadow: 0 4rpx 30rpx rgba(0,0,0,0.03); }
.grid-item { flex: 1; display: flex; flex-direction: column; align-items: center; font-size: 26rpx; color: #64748b; transition: all 0.2s; }
.grid-item.active { color: #1e293b; font-weight: bold; transform: scale(1.05); }
.icon-circle { width: 95rpx; height: 95rpx; border-radius: 32rpx; display: flex; align-items: center; justify-content: center; font-size: 44rpx; margin-bottom: 12rpx; }
.bg-blue { background: #e0f2fe; } .bg-purple { background: #f5f3ff; } .bg-green { background: #f0fdf4; } .bg-red { background: #fff1f2; }

/* 内容区域 */
.main-content { padding: 0 30rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 5rpx 20rpx; }
.main-title { font-size: 36rpx; font-weight: 800; color: #1e293b; }
.publish-btn { background: #2563eb; color: #fff; font-size: 24rpx; padding: 12rpx 28rpx; border-radius: 30rpx; }
.purple-btn { background: #8b5cf6; } .green-btn { background: #10b981; }

/* 现代卡片布局 (校园墙 & 跑腿) */
.modern-card { background: #fff; border-radius: 32rpx; padding: 35rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02); }
.card-user { display: flex; align-items: center; margin-bottom: 25rpx; }
.user-avatar-placeholder { width: 80rpx; height: 80rpx; border-radius: 40rpx; background: #f1f5f9; text-align: center; line-height: 80rpx; font-size: 40rpx; }
.user-info { margin-left: 20rpx; }
.user-name { font-size: 30rpx; font-weight: 700; color: #1e293b; }
.user-time { font-size: 24rpx; color: #94a3b8; margin-top: 4rpx; }
.content-text { font-size: 34rpx; line-height: 1.7; color: #334155; display: block; letter-spacing: 1rpx; }
.content-img { width: 100%; border-radius: 20rpx; margin-top: 25rpx; }
.card-footer { display: flex; justify-content: space-between; margin-top: 30rpx; padding-top: 20rpx; border-top: 1rpx solid #f8fafc; }
.wall-tag { color: #2563eb; font-size: 24rpx; font-weight: bold; background: #eff6ff; padding: 4rpx 16rpx; border-radius: 8rpx; }
.interaction-row text { margin-left: 30rpx; font-size: 26rpx; color: #64748b; }

/* 跑腿专属 */
.task-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.task-price { color: #f59e0b; font-size: 40rpx; font-weight: 800; }
.task-time-tag { background: #fff7ed; color: #f59e0b; font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 10rpx; font-weight: bold; }
.loc-tag { font-size: 26rpx; color: #64748b; margin-top: 20rpx; font-weight: 500; }
.action-btn { background: #8b5cf6; color: #fff; font-size: 28rpx; margin-top: 30rpx; border-radius: 16rpx; border: none; }

/* 闲置市场瀑布流 */
.market-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.m-card { width: calc(50% - 10rpx); background: #fff; border-radius: 24rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02); }
.m-img { width: 100%; height: 260rpx; background: #f1f5f9; }
.m-content-box { padding: 20rpx; }
.m-text { font-size: 28rpx; height: 80rpx; line-height: 40rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: #334155; }
.m-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 15rpx; }
.m-price { color: #ef4444; font-weight: 800; font-size: 32rpx; }
.m-badge { font-size: 18rpx; background: #f0fdf4; color: #10b981; padding: 2rpx 10rpx; border-radius: 4rpx; }

/* 外卖列表 */
.food-card { background: #fff; border-radius: 32rpx; padding: 25rpx; margin-bottom: 25rpx; display: flex; }
.food-img { width: 170rpx; height: 170rpx; border-radius: 24rpx; flex-shrink: 0; }
.food-info { flex: 1; margin-left: 25rpx; display: flex; flex-direction: column; justify-content: space-between; }
.food-name { font-size: 32rpx; font-weight: bold; color: #1e293b; }
.food-tag { font-size: 20rpx; color: #ef4444; border: 1rpx solid #ef4444; padding: 2rpx 10rpx; border-radius: 6rpx; margin-left: 15rpx; font-weight: normal; }
.food-score { font-size: 24rpx; color: #f59e0b; margin: 8rpx 0; font-weight: bold; }
.sales { color: #94a3b8; font-size: 22rpx; margin-left: 20rpx; font-weight: normal; }
.food-bottom { display: flex; justify-content: space-between; align-items: center; }
.food-price { font-size: 24rpx; color: #64748b; }
.order-btn { margin: 0; font-size: 24rpx; background: #ef4444; color: #fff; border-radius: 30rpx; padding: 0 30rpx; height: 56rpx; line-height: 56rpx; }

.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }