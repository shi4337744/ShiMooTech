<view class="fav-container">
  
  <view class="empty-state" wx:if="{{favList.length === 0}}">
    <view class="empty-icon">🌟</view>
    <text>暂无收藏，快去广场逛逛吧</text>
  </view>

  <view class="fav-list">
    <view class="fav-card fade-in" wx:for="{{favList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-type="{{item.type}}">
      
      <image class="fav-img" src="{{item.imageUrl}}" mode="aspectFill" wx:if="{{item.imageUrl && item.type !== 'errand'}}"></image>
      <view class="fav-img placeholder-img" wx:elif="{{item.type === 'errand'}}">🏃</view>
      
      <view class="fav-info">
        <view class="f-top">
          <text class="badge type-{{item.type}}">{{item.type === 'wall' ? '校园墙' : (item.type === 'errand' ? '跑腿' : '闲置')}}</text>
          <text class="f-time">{{item.time}}</text>
        </view>
        
        <text class="f-content">{{item.content}}</text>
        
        <view class="f-bottom">
          <text class="f-price" wx:if="{{item.type === 'errand' || item.type === 'market'}}">￥{{item.price}}</text>
          <text class="f-price transparent" wx:else>￥0</text>
          
          <view class="unfav-btn" catchtap="cancelFavorite" data-id="{{item.id}}">取消收藏</view>
        </view>
      </view>

    </view>
  </view>

</view>