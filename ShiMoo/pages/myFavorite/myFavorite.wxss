page { background: #f4f7fa; }
.fav-container { padding: 30rpx; }

.empty-state { text-align: center; padding: 200rpx 0; color: #94a3b8; }
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; opacity: 0.5; }

.fav-card { display: flex; background: #fff; border-radius: 24rpx; padding: 25rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); }
.fav-img { width: 180rpx; height: 180rpx; border-radius: 16rpx; margin-right: 25rpx; flex-shrink: 0; background: #f1f5f9; }
.placeholder-img { display: flex; justify-content: center; align-items: center; font-size: 60rpx; background: #f5f3ff; }

.fav-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; overflow: hidden; }
.f-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15rpx; }
.badge { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; font-weight: bold; color: #fff; }
.type-wall { background: #3b82f6; }
.type-errand { background: #8b5cf6; }
.type-market { background: #10b981; }
.f-time { font-size: 22rpx; color: #94a3b8; }

.f-content { font-size: 28rpx; color: #334155; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; margin-bottom: 20rpx; }

.f-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
.f-price { font-size: 32rpx; font-weight: 900; color: #ef4444; }
.f-price.transparent { color: transparent; } /* 保持占位不塌陷 */

.unfav-btn { font-size: 24rpx; color: #64748b; background: #f1f5f9; padding: 10rpx 24rpx; border-radius: 30rpx; transition: all 0.2s; }
.unfav-btn:active { background: #e2e8f0; }

.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }