page { background: #f4f7fa; }

/* 顶部 Tab */
.sticky-header { position: sticky; top: 0; z-index: 100; background: #fff; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03); }
.tab-scroll { white-space: nowrap; padding: 20rpx 30rpx; }
.tab-item { display: inline-block; font-size: 28rpx; color: #64748b; padding: 10rpx 30rpx; margin-right: 20rpx; border-radius: 30rpx; background: #f1f5f9; transition: all 0.2s; }
.tab-item.active { background: #3b82f6; color: #fff; font-weight: bold; }

/* 列表区 */
.list-container { padding: 30rpx; }
.empty-state { text-align: center; padding: 150rpx 0; color: #94a3b8; }
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; opacity: 0.5; }

.post-card { background: #fff; border-radius: 24rpx; padding: 35rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); }
.card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; border-bottom: 1rpx dashed #f1f5f9; padding-bottom: 20rpx; }
.badge { font-size: 24rpx; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: bold; color: #fff; }
.type-wall { background: #3b82f6; }
.type-errand { background: #8b5cf6; }
.type-market { background: #10b981; }

.status-text { font-size: 26rpx; font-weight: bold; }
.text-gray { color: #94a3b8; }
.text-orange { color: #f59e0b; }
.text-green { color: #10b981; }

.card-body { margin-bottom: 25rpx; }
.content-text { font-size: 30rpx; color: #1e293b; line-height: 1.6; display: block; margin-bottom: 15rpx; }
.content-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: #f1f5f9; }
.meta-row { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 15rpx; }
.price { font-size: 36rpx; font-weight: 900; color: #ef4444; }
.time { font-size: 24rpx; color: #94a3b8; }

/* 底部操作区 */
.card-foot { display: flex; justify-content: flex-end; gap: 20rpx; border-top: 1rpx solid #f8fafc; padding-top: 25rpx; }
.action-btn { font-size: 26rpx; padding: 12rpx 30rpx; border-radius: 30rpx; font-weight: bold; transition: all 0.2s; }
.action-btn:active { transform: scale(0.95); }
.action-btn.edit { background: #eff6ff; color: #3b82f6; }
.action-btn.delete { background: #fee2e2; color: #ef4444; }
.action-btn.appeal { background: #fef3c7; color: #d97706; }

.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }