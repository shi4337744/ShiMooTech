<view class="mypublish-container">
  <view class="sticky-header">
    <scroll-view scroll-x class="tab-scroll">
      <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
      <view class="tab-item {{currentTab === 'wall' ? 'active' : ''}}" bindtap="switchTab" data-tab="wall">校园墙</view>
      <view class="tab-item {{currentTab === 'errand' ? 'active' : ''}}" bindtap="switchTab" data-tab="errand">跑腿订单</view>
      <view class="tab-item {{currentTab === 'market' ? 'active' : ''}}" bindtap="switchTab" data-tab="market">闲置订单</view>
    </scroll-view>
  </view>

  <view class="list-container">
    <view class="empty-state" wx:if="{{myList.length === 0}}">
      <view class="empty-icon">📂</view>
      <text>暂无相关发布记录</text>
    </view>

    <view class="post-card fade-in" wx:for="{{myList}}" wx:key="id" wx:if="{{currentTab === 'all' || currentTab === item.type}}">
      
      <view class="card-head">
        <view class="badge type-{{item.type}}">
          {{item.type === 'wall' ? '校园墙' : (item.type === 'errand' ? '跑腿' : '闲置')}}
        </view>
        <view class="status-text {{item.orderStatus === 'completed' ? 'text-green' : (item.orderStatus ? 'text-orange' : 'text-gray')}}">
          {{item.orderStatus === 'pending' ? '等待中' : ''}}
          {{item.orderStatus === 'processing' ? '处理中' : ''}}
          {{item.orderStatus === 'delivered' ? '待我收货' : ''}}
          {{item.orderStatus === 'completed' ? '已完结' : ''}}
          {{!item.orderStatus ? '展示中' : ''}} </view>
      </view>

      <view class="card-body">
        <text class="content-text">{{item.content}}</text>
        <image wx:if="{{item.imageUrl}}" class="content-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
        
        <view class="meta-row" wx:if="{{item.type === 'errand' || item.type === 'market'}}">
          <text class="price">￥{{item.price}}</text>
          <text class="time">{{item.time}}</text>
        </view>
      </view>

      <view class="card-foot">
        
        <block wx:if="{{item.type === 'wall'}}">
          <view class="action-btn edit" bindtap="editPost" data-id="{{item.id}}">编辑文字</view>
          <view class="action-btn delete" bindtap="deletePost" data-id="{{item.id}}">删除帖子</view>
        </block>

        <block wx:if="{{(item.type === 'errand' || item.type === 'market') && item.orderStatus !== 'completed'}}">
          <view class="action-btn delete" bindtap="deletePost" data-id="{{item.id}}">取消发布 / 撤单</view>
        </block>

        <block wx:if="{{item.orderStatus === 'completed'}}">
          <view class="action-btn appeal" bindtap="appealOrder" data-id="{{item.id}}">申请售后/申诉</view>
          <view class="action-btn delete" bindtap="deletePost" data-id="{{item.id}}">删除记录</view>
        </block>

      </view>
    </view>
  </view>
</view>