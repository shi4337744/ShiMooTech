view, scroll-view, text, image, button, input { box-sizing: border-box; }
page { background: #f4f7fa; }
.hall-container { padding-bottom: 50rpx; }

/* 顶部粘性过滤栏 */
.sticky-header { position: sticky; top: 0; z-index: 100; background: #fff; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); }
.tab-scroll { white-space: nowrap; padding: 25rpx 30rpx; }
.tab-item { display: inline-block; font-size: 26rpx; color: #64748b; padding: 12rpx 32rpx; margin-right: 20rpx; border-radius: 40rpx; background: #f1f5f9; transition: all 0.2s; border: 2rpx solid transparent;}
.tab-item.active { background: #ecfdf5; color: #10b981; font-weight: bold; border-color: #a7f3d0; }

/* 列表区 */
.list-section { padding: 30rpx; }
.empty-state { text-align: center; padding: 200rpx 0; color: #94a3b8; }
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; opacity: 0.5; }

/* 闲置瀑布流网格 */
.market-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.m-card { width: 48%; background: #ffffff; border-radius: 20rpx; overflow: hidden; margin-bottom: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04); display: flex; flex-direction: column;}
.m-img { width: 100%; height: 340rpx; background: #f1f5f9; }
.m-content-box { padding: 25rpx 20rpx; display: flex; flex-direction: column; flex: 1; justify-content: space-between;}
.m-title { font-size: 28rpx; font-weight: bold; color: #334155; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 20rpx; line-height: 1.5; }
.m-tags { display: flex; gap: 12rpx; margin-bottom: 20rpx; flex-wrap: wrap;}
.m-tag { font-size: 20rpx; padding: 6rpx 12rpx; border-radius: 8rpx; font-weight: bold; }
.m-tag.trade { background: #dcfce7; color: #16a34a; }
.m-tag.condition { background: #f1f5f9; color: #64748b; }
.m-price-row { display: flex; align-items: baseline; margin-bottom: 20rpx; }
.m-price { color: #ef4444; font-size: 38rpx; font-weight: 900; margin-right: 12rpx; }
.m-symbol { font-size: 24rpx; }
.m-original-price { color: #94a3b8; font-size: 22rpx; text-decoration: line-through; }
.m-user-row { display: flex; justify-content: space-between; align-items: center; border-top: 1rpx solid #f8fafc; padding-top: 20rpx; }
.m-user { display: flex; align-items: center; max-width: 60%; }
.m-avatar { width: 40rpx; height: 40rpx; background: #e2e8f0; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 22rpx; margin-right: 12rpx; flex-shrink: 0; }
.m-name { font-size: 24rpx; color: #64748b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 500;}
.m-action { display: flex; align-items: center; }
.m-like { font-size: 24rpx; color: #94a3b8; display: flex; align-items: center; gap: 8rpx; transition: all 0.2s;}
.m-like.liked { color: #ef4444; font-weight: bold; }

.pop-animation { animation: pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
@keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.4); } 100% { transform: scale(1); } }
.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(15rpx); } to { opacity: 1; transform: translateY(0); } }