<view class="hall-container">
  <view class="sticky-header">
    <scroll-view scroll-x class="tab-scroll">
      <view class="tab-item {{filterType === 'all' ? 'active' : ''}}" bindtap="changeFilter" data-type="all">全部好物</view>
      <view class="tab-item {{filterType === '二手出售' ? 'active' : ''}}" bindtap="changeFilter" data-type="二手出售">💰 二手出售</view>
      <view class="tab-item {{filterType === '闲置租赁' ? 'active' : ''}}" bindtap="changeFilter" data-type="闲置租赁">🔄 闲置租赁</view>
    </scroll-view>
  </view>

  <view class="list-section">
    <view class="empty-state" wx:if="{{displayList.length === 0}}">
      <view class="empty-icon">📦</view>
      <text>当前分类下暂无闲置物品</text>
    </view>

    <view class="market-grid" wx:else>
      <view class="m-card fade-in" wx:for="{{displayList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-type="market">
        <image class="m-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
        
        <view class="m-content-box">
          <text class="m-title">{{item.content}}</text>
          
          <view class="m-tags">
            <text class="m-tag trade">{{item.tradeType}}</text>
            <text class="m-tag condition">{{item.condition}}</text>
          </view>
          
          <view class="m-price-row">
            <text class="m-price"><text class="m-symbol">￥</text>{{item.price}}</text>
            <text class="m-original-price" wx:if="{{item.originalPrice}}">￥{{item.originalPrice}}</text>
          </view>
          
          <view class="m-user-row">
            <view class="m-user">
              <view class="m-avatar">👤</view>
              <text class="m-name">{{item.userName}}</text>
            </view>
            <view class="m-action">
              <view class="m-like {{item.isLiked ? 'liked' : ''}} {{item.isAnimating ? 'pop-animation' : ''}}" catchtap="handleLike" data-id="{{item.id}}">
                {{item.isLiked ? '❤️' : '🤍'}} {{item.likes || item.likeCount || 0}}
              </view>
            </view>
          </view>
        </view>

      </view>
    </view>
  </view>
</view>