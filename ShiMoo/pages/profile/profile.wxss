view, text, image, input { box-sizing: border-box; }
page { background: #f4f7fa; }
.profile-container { padding: 40rpx 30rpx; }

.avatar-section { display: flex; flex-direction: column; align-items: center; margin-bottom: 60rpx; position: relative; }
.avatar-img { width: 180rpx; height: 180rpx; border-radius: 50%; border: 6rpx solid #fff; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05); background: #e2e8f0;}
.camera-icon { position: absolute; bottom: 50rpx; right: calc(50% - 90rpx); background: #2563eb; width: 50rpx; height: 50rpx; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 24rpx; border: 4rpx solid #fff; }
.avatar-tips { font-size: 24rpx; color: #94a3b8; margin-top: 20rpx; }

.form-group { background: #fff; border-radius: 24rpx; padding: 0 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02); }
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 35rpx 0; border-bottom: 1rpx solid #f8fafc; }
.form-item:last-child { border-bottom: none; }
.form-label { font-size: 30rpx; color: #334155; width: 160rpx; font-weight: bold; }
.form-input { flex: 1; text-align: right; font-size: 30rpx; color: #1e293b; }

.save-btn { margin-top: 80rpx; background: #2563eb; color: #fff; height: 90rpx; border-radius: 45rpx; display: flex; justify-content: center; align-items: center; font-size: 32rpx; font-weight: bold; box-shadow: 0 10rpx 20rpx rgba(37,99,235,0.2); transition: all 0.2s;}
.save-btn:active { transform: scale(0.98); background: #1d4ed8;}