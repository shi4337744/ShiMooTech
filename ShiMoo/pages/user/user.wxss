page {
  background-color: #f9fafb;
}

/* 顶部个人信息区 */
.user-header {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  height: 380rpx;
  padding: 60rpx 40rpx 0;
  position: relative;
}

.user-card {
  display: flex;
  align-items: center;
  position: relative;
}

.avatar-container {
  position: relative;
  margin-right: 30rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 70rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  background: #ffffff;
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.user-info {
  flex: 1;
  color: white;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.level-tag {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: normal;
}

.user-id, .user-school {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 10rpx;
}

.setting-icon {
  font-size: 44rpx;
  color: white;
  position: absolute;
  top: 0;
  right: 0;
}

/* 数据统计栏 */
.stats-section {
  padding: 0 30rpx;
  margin-top: -80rpx; /* 向上偏移，压在蓝区上 */
  position: relative;
  z-index: 10;
}

.stats-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.stats-item {
  text-align: center;
}

.stats-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #6b7280;
}

/* 功能列表区 */
.menu-section {
  padding: 40rpx 30rpx;
}

.menu-group {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #374151;
}

.menu-right {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.green {
  color: #10b981;
}

.arrow {
  font-size: 24rpx;
  color: #d1d5db;
}

/* 退出按钮 */
.logout-btn {
  margin-top: 40rpx;
  background: white;
  color: #ef4444;
  text-align: center;
  padding: 30rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}