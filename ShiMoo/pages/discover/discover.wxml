<view class="discover-container">
  <view class="sticky-header">
    <scroll-view scroll-x class="tab-scroll">
      <view class="tab-item {{filterType === 'all' ? 'active' : ''}}" bindtap="changeFilter" data-type="all">全部动态</view>
      <view class="tab-item {{filterType === 'wall' ? 'active' : ''}}" bindtap="changeFilter" data-type="wall">校园墙</view>
      <view class="tab-item {{filterType === 'errand' ? 'active' : ''}}" bindtap="changeFilter" data-type="errand">跑腿</view>
      <view class="tab-item {{filterType === 'market' ? 'active' : ''}}" bindtap="changeFilter" data-type="market">闲置</view>
    </scroll-view>
  </view>

  <view class="feed-flow">
    <block wx:for="{{discoveryList}}" wx:key="id">
      
      <view class="task-card fade-in" wx:if="{{(filterType === 'all' || filterType === 'errand') && item.type === 'errand'}}" bindtap="goToDetail" data-id="{{item.id}}" data-type="errand">
        <view class="task-top">
          <view class="task-user">
            <view class="tu-avatar">🏃</view>
            <text class="tu-name">{{item.userName}}</text>
          </view>
          <view class="task-price">￥<text class="price-num">{{item.price}}</text></view>
        </view>
        
        <text class="task-title">{{item.content}}</text>
        
        <view class="task-info-list">
          <view class="ti-item">
            <text class="ti-icon">🕒</text>
            <text>限 {{item.deadline}} 前完成</text>
          </view>
          <view class="ti-item">
            <text class="ti-icon">📍</text>
            <text>送至：{{item.location}}</text>
          </view>
        </view>
        
        <view class="task-bot">
          <view class="task-tags">
            <text class="t-tag urgent" wx:if="{{item.urgent}}">🔥 急单</text>
            <text class="t-tag type" wx:if="{{item.taskType}}">{{item.taskType}}</text>
          </view>
          <button class="task-btn" catchtap="takeOrder" data-index="{{index}}">立即接单</button>
        </view>
      </view>


      <view class="feed-card fade-in" wx:if="{{(filterType === 'all' || filterType === item.type) && item.type !== 'errand'}}" bindtap="goToDetail" data-id="{{item.id}}" data-type="{{item.type}}">
        <view class="card-header">
          <view class="u-box">
            <view class="u-avatar">{{item.type === 'market' ? '🎁' : '👤'}}</view>
            <view class="u-meta">
              <text class="u-name">{{item.userName}}</text>
              <text class="u-time">{{item.time}} · {{item.location}}</text>
            </view>
          </view>
          <view class="badge tag-{{item.type}}">{{item.type === 'wall' ? '校园墙' : '闲置'}}</view>
        </view>

        <view class="card-content">
          <text class="custom-tag" wx:if="{{item.tag && item.type === 'wall'}}">#{{item.tag}}</text>
          <text class="text">{{item.content}}</text>
          <image wx:if="{{item.imageUrl}}" class="img" src="{{item.imageUrl}}" mode="widthFix" lazy-load></image>
        </view>

        <view class="market-info-box" wx:if="{{item.type === 'market'}}">
          <text class="m-price">￥{{item.price}}</text>
          <text class="m-type">{{item.condition}}</text>
          <text class="m-type">{{item.tradeType}}</text>
        </view>

        <view class="card-footer">
          <view class="interaction-box">
            <view class="btn {{item.isLiked ? 'liked' : ''}} {{item.isAnimating ? 'pop-animation' : ''}}" catchtap="handleLike" data-index="{{index}}" data-id="{{item.id}}">
              {{item.isLiked ? '❤️' : '🤍'}} {{item.likeCount > 0 ? item.likeCount : '赞'}}
            </view>
            <view class="btn">💬 {{item.commentCount || '评论'}}</view>
            <button class="btn share-btn" open-type="share" catchtap="preventTap">🚀 分享</button>
          </view>

          <block wx:if="{{item.userName === '我发布的' || item.userName === '自己(测试)'}}">
            <view class="self-actions-box">
              <view class="btn self-action edit" catchtap="editPost" data-id="{{item.id}}">编辑</view>
              <view class="btn self-action delete" catchtap="deletePost" data-id="{{item.id}}">删除</view>
            </view>
          </block>
        </view>
      </view>

    </block>
  </view>
</view>