page { background: #f4f7fa; }
.discover-container { padding-bottom: 30rpx; }

/* 顶部导航 */
.tab-scroll { white-space: nowrap; background: #fff; padding: 20rpx; position: sticky; top: 0; z-index: 100; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.tab-item { display: inline-block; padding: 12rpx 35rpx; margin-right: 20rpx; font-size: 26rpx; border-radius: 30rpx; background: #f1f5f9; color: #64748b; }
.tab-item.active { background: #2563eb; color: #fff; font-weight: bold; }

/* 卡片流 */
.feed-flow { padding: 25rpx; padding-bottom: 120rpx;}
.feed-card { background: #fff; border-radius: 32rpx; padding: 30rpx; margin-bottom: 25rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02); }
.card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 25rpx; }
.u-box { display: flex; align-items: center; }
.u-avatar { width: 75rpx; height: 75rpx; background: #e2e8f0; border-radius: 50%; text-align: center; line-height: 75rpx; font-size: 40rpx; margin-right: 18rpx; }
.u-name { font-size: 30rpx; font-weight: bold; color: #1e293b; display: block; }
.u-time { font-size: 22rpx; color: #94a3b8; }
.badge { font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: bold; }
.tag-wall { background: #e0f2fe; color: #0284c7; }
.tag-errand { background: #fef3c7; color: #d97706; }
.tag-market { background: #dcfce7; color: #16a34a; }
.tag-food { background: #fee2e2; color: #dc2626; }

/* 正文样式 */
.card-content .text { font-size: 30rpx; line-height: 1.6; color: #334155; margin-bottom: 15rpx; display: block; }
.card-content .img { width: 100%; border-radius: 20rpx; margin-top: 15rpx; }
.custom-tag { display: inline-block; color: #3b82f6; background: #eff6ff; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; margin-bottom: 15rpx; font-weight: bold; }

/* 🚀 跑腿专属内联框 (之前丢的) */
.errand-info-box { background: #f8fafc; border-radius: 12rpx; padding: 20rpx; margin-top: 20rpx; border: 1rpx solid #f1f5f9; }
.e-row { font-size: 26rpx; color: #475569; margin-bottom: 10rpx; display: flex; align-items: center; }
.e-row:last-child { margin-bottom: 0; }
.e-icon { margin-right: 10rpx; }
.e-price { color: #ef4444; font-weight: bold; font-size: 30rpx; }

/* 🚀 闲置专属内联框 (之前丢的) */
.market-info-box { margin-top: 20rpx; display: flex; align-items: baseline; gap: 15rpx; }
.m-price { color: #ef4444; font-size: 36rpx; font-weight: 900; }
.m-type { font-size: 22rpx; color: #16a34a; background: #dcfce7; padding: 4rpx 12rpx; border-radius: 6rpx; }

/* 底部交互区与管理按钮 */
.card-footer { display: flex; flex-direction: row; justify-content: space-between; align-items: center; margin-top: 30rpx; padding-top: 20rpx; border-top: 1rpx solid #f8fafc; flex-wrap: nowrap;}
.interaction-box { display: flex; flex-direction: row; align-items: center; gap: 30rpx; }
.self-actions-box { display: flex; flex-direction: row; align-items: center; gap: 15rpx;}
.btn { font-size: 26rpx; color: #64748b; background: transparent; margin: 0; padding: 0; line-height: normal; display: flex; align-items: center; gap: 8rpx;}
.btn::after { border: none; }
.btn.liked { color: #ef4444; font-weight: bold;}
.share-btn { margin-right: 0 !important; }

.self-action { padding: 8rpx 20rpx; border-radius: 8rpx; font-size: 24rpx; margin-left: 0; }
.self-action.edit { color: #3b82f6; background: #eff6ff; }
.self-action.delete { color: #ef4444; background: #fee2e2; }

.errand-footer { justify-content: space-between; align-items: center; }
.e-btn { margin: 0; background: #3b82f6; color: #fff; font-size: 26rpx; font-weight: bold; padding: 0 40rpx; height: 60rpx; line-height: 60rpx; border-radius: 30rpx; }
.pop-animation { animation: pop 0.3s ease-in-out; }
@keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.4); } 100% { transform: scale(1); } }
.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }

/* ========================================================== */
/* 🚀 从首页移植过来的跑腿大厅专属卡片样式 (Task Card) */
/* ========================================================== */
.task-card { background: #ffffff; border-radius: 24rpx; padding: 30rpx; margin-bottom: 25rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02); }
.task-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.task-user { display: flex; align-items: center; }
.tu-avatar { width: 60rpx; height: 60rpx; background: #f5f3ff; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 30rpx; margin-right: 15rpx; }
.tu-name { font-size: 28rpx; font-weight: bold; color: #1e293b; }
.task-price { color: #ef4444; font-size: 24rpx; font-weight: bold; }
.price-num { font-size: 44rpx; }
.task-title { font-size: 32rpx; font-weight: bold; color: #334155; line-height: 1.5; display: block; margin-bottom: 20rpx; }
.task-info-list { background: #f8fafc; border-radius: 12rpx; padding: 20rpx; margin-bottom: 25rpx; }
.ti-item { display: flex; align-items: center; font-size: 26rpx; color: #64748b; margin-bottom: 10rpx; }
.ti-item:last-child { margin-bottom: 0; }
.ti-icon { margin-right: 10rpx; }
.task-bot { display: flex; justify-content: space-between; align-items: center; border-top: 1rpx solid #f1f5f9; padding-top: 25rpx; }
.task-tags { display: flex; gap: 15rpx; }
.t-tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: bold; }
.t-tag.urgent { background: #fee2e2; color: #ef4444; }
.t-tag.type { background: #e0e7ff; color: #4f46e5; }
.task-btn { margin: 0; background: #3b82f6; color: #ffffff; font-size: 28rpx; padding: 12rpx 40rpx; border-radius: 40rpx; font-weight: bold; box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.3); }