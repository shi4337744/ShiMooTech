page { background: #f4f7fa; }
.discover-container { padding-bottom: 30rpx; }

/* 顶部导航 */
.tab-scroll { white-space: nowrap; background: #fff; padding: 20rpx; position: sticky; top: 0; z-index: 100; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.tab-item { display: inline-block; padding: 12rpx 35rpx; margin-right: 20rpx; font-size: 26rpx; border-radius: 30rpx; background: #f1f5f9; color: #64748b; }
.tab-item.active { background: #2563eb; color: #fff; font-weight: bold; }

/* 卡片流 */
.feed-flow { padding: 25rpx; }
.feed-card { background: #fff; border-radius: 32rpx; padding: 30rpx; margin-bottom: 25rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02); }
.card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 25rpx; }
.u-box { display: flex; align-items: center; }
.u-avatar { width: 75rpx; height: 75rpx; background: #e2e8f0; border-radius: 50%; text-align: center; line-height: 75rpx; font-size: 40rpx; margin-right: 18rpx; }
.u-name { font-size: 30rpx; font-weight: bold; color: #1e293b; display: block; }
.u-time { font-size: 22rpx; color: #94a3b8; }

/* 标签颜色定义 */
.badge { font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: bold; }
.tag-wall { background: #e0f2fe; color: #0284c7; }
.tag-errand { background: #fef3c7; color: #d97706; }
.tag-market { background: #dcfce7; color: #16a34a; }
.tag-food { background: #fee2e2; color: #dc2626; }

/* 内容展示 */
.card-content .text { font-size: 33rpx; line-height: 1.6; color: #334155; }
.card-content .img { width: 100%; border-radius: 20rpx; margin-top: 20rpx; }
.price-bar { margin-top: 20rpx; background: #f8fafc; padding: 15rpx 25rpx; border-radius: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.price-val { color: #ef4444; font-size: 36rpx; font-weight: 800; }
.type-hint { font-size: 22rpx; color: #94a3b8; }

.card-footer { display: flex; gap: 50rpx; margin-top: 30rpx; padding-top: 20rpx; border-top: 1rpx solid #f1f5f9; }
.card-footer .btn { font-size: 26rpx; color: #64748b; }

.empty-hint { text-align: center; color: #94a3b8; padding: 100rpx 0; font-size: 28rpx; }
.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }