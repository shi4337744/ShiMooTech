/* 🚀 核心修复：全局开启安全盒模型，彻底解决 padding 撑爆屏幕和靠边的问题 */
view, scroll-view, text, image, button, input { box-sizing: border-box; }

page { background-color: #f8fafc; height: 100vh; overflow: hidden; }
.shop-container { display: flex; flex-direction: column; height: 100%; position: relative; width: 100vw; }

/* 头部店招 */
.shop-header { width: 100%; background: linear-gradient(135deg, #1e293b, #334155); padding: 40rpx 30rpx 50rpx; border-bottom-left-radius: 30rpx; border-bottom-right-radius: 30rpx; z-index: 10; }
.shop-title { font-size: 40rpx; font-weight: 900; color: #ffffff; display: block; margin-bottom: 15rpx; }
.shop-desc { font-size: 24rpx; color: #cbd5e1; }

/* 菜单列表 */
.menu-list { flex: 1; height: 0; width: 100%; padding: 20rpx 30rpx; }
.menu-item { display: flex; width: 100%; background: #ffffff; border-radius: 20rpx; padding: 25rpx; margin-bottom: 25rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02); }
.m-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: #f1f5f9; margin-right: 25rpx; flex-shrink: 0; }
.m-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; overflow: hidden; }
.m-name { font-size: 32rpx; font-weight: bold; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.m-desc { font-size: 22rpx; color: #94a3b8; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; margin-top: 8rpx; }
.m-sales { font-size: 22rpx; color: #64748b; margin-top: 8rpx; }
.m-bottom { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 15rpx; width: 100%; }
.m-price { font-size: 36rpx; font-weight: 900; color: #ef4444; }
.m-symbol { font-size: 24rpx; }
.bottom-spacer { height: 180rpx; }

/* 步进器 (加减号) - 保证宽高不被挤压 */
.stepper { display: flex; align-items: center; flex-shrink: 0; }
.step-btn { width: 44rpx; height: 44rpx; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 36rpx; font-weight: bold; line-height: 40rpx; flex-shrink: 0; }
.step-btn.minus { border: 2rpx solid #cbd5e1; color: #94a3b8; background: #ffffff; }
.step-btn.plus { background: #3b82f6; color: #ffffff; box-shadow: 0 4rpx 10rpx rgba(59,130,246,0.3); }
.step-num { font-size: 28rpx; font-weight: bold; color: #1e293b; width: 60rpx; text-align: center; }

/* ================= 购物车明细弹窗 ================= */
.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 20; opacity: 0; visibility: hidden; transition: all 0.3s; }
.mask.show { opacity: 1; visibility: visible; }

/* 🚀 核心修复：弹窗底部加入全面屏安全距离适配 */
.cart-popup { position: fixed; bottom: 0; left: 0; right: 0; background: #ffffff; border-top-left-radius: 30rpx; border-top-right-radius: 30rpx; z-index: 25; padding-bottom: calc(140rpx + env(safe-area-inset-bottom)); transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
.cart-popup.show { transform: translateY(0); }
.cp-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 40rpx; background: #f8fafc; border-top-left-radius: 30rpx; border-top-right-radius: 30rpx; }
.cp-title { font-size: 28rpx; color: #64748b; font-weight: bold; }
.cp-clear { font-size: 24rpx; color: #94a3b8; display: flex; align-items: center; padding: 10rpx; }
.cp-list { max-height: 50vh; padding: 0 40rpx; }
.cp-item { display: flex; justify-content: space-between; align-items: center; padding: 35rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.cp-name-box { flex: 1; padding-right: 20rpx; }
.cp-name { font-size: 30rpx; font-weight: bold; color: #334155; }
.cp-right { display: flex; align-items: center; gap: 40rpx; flex-shrink: 0; }
.cp-price { font-size: 32rpx; font-weight: 900; color: #ef4444; }

/* ================= 底部常驻购物车栏 ================= */
/* 🚀 核心修复：加入 env(safe-area-inset-bottom) 防止被 iPhone 底部小黑条遮挡，并加入 overflow: hidden 保证圆角完美 */
.bottom-bar { position: fixed; bottom: calc(30rpx + env(safe-area-inset-bottom)); left: 30rpx; right: 30rpx; height: 100rpx; background: #1e293b; border-radius: 50rpx; display: flex; align-items: center; justify-content: space-between; z-index: 30; box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15); padding-left: 30rpx; overflow: hidden; }
.cart-left { display: flex; align-items: center; flex: 1; height: 100%; }

.cart-icon-box { position: relative; width: 80rpx; height: 80rpx; background: #334155; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 40rpx; margin-top: -30rpx; border: 8rpx solid #1e293b; transition: all 0.3s; flex-shrink: 0; }
.cart-icon-box.active { background: #3b82f6; }
.cart-icon { margin-top: -4rpx; }
.cart-badge { position: absolute; top: -10rpx; right: -10rpx; background: #ef4444; color: #ffffff; font-size: 20rpx; font-weight: bold; min-width: 32rpx; height: 32rpx; border-radius: 16rpx; display: flex; justify-content: center; align-items: center; border: 4rpx solid #1e293b; padding: 0 6rpx; }

/* 购物车跳动动画 */
.bounce { animation: bounce 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
@keyframes bounce { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }

.price-box { margin-left: 20rpx; display: flex; flex-direction: column; justify-content: center; flex: 1; overflow: hidden; }
.total-price { font-size: 36rpx; font-weight: 900; color: #ffffff; white-space: nowrap; }
.empty-text { font-size: 26rpx; color: #94a3b8; white-space: nowrap; }

/* 🚀 核心修复：结算按钮固定宽度，防止文字变动时按钮忽大忽小挤出屏幕 */
.checkout-btn { height: 100%; min-width: 200rpx; padding: 0 30rpx; background: #334155; color: #94a3b8; display: flex; justify-content: center; align-items: center; font-size: 28rpx; font-weight: bold; transition: all 0.3s; flex-shrink: 0; }
.checkout-btn.ready { background: #10b981; color: #ffffff; font-size: 30rpx; }