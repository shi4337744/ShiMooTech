<view class="detail-page">
  <view class="shop-header">
    <view class="shop-title">{{shopName}}</view>
    <view class="shop-tags"><text>⭐ 4.8</text><text>蜂鸟专送</text><text>校园配送</text></view>
  </view>

  <view class="menu-box">
    <view class="menu-item" wx:for="{{menu}}" wx:key="id">
      <image class="dish-img" src="{{item.img}}" mode="aspectFill"></image>
      <view class="dish-info">
        <view class="dish-name">{{item.name}}</view>
        <view class="dish-sales">月售 {{item.sales}}</view>
        <view class="dish-price-row">
          <text class="price">￥{{item.price}}</text>
          <view class="add-btn" bindtap="addToCart" data-item="{{item}}">+</view>
        </view>
      </view>
    </view>
  </view>

  <view class="cart-mask" wx:if="{{showCartPopup}}" bindtap="toggleCart"></view>

  <view class="cart-popup {{showCartPopup ? 'popup-show' : ''}}">
    <view class="popup-header">
      <text>已选商品</text>
      <text class="clear-all" bindtap="clearCart">🗑️ 清空购物车</text>
    </view>
    <scroll-view scroll-y class="cart-list-scroll">
      <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
        <text class="cart-item-name">{{item.name}}</text>
        <view class="cart-item-right">
          <text class="cart-item-price">￥{{item.price * item.count}}</text>
          <view class="stepper">
            <view class="step-btn minus" bindtap="minusCart" data-id="{{item.id}}">-</view>
            <text class="step-num">{{item.count}}</text>
            <view class="step-btn plus" bindtap="addToCart" data-item="{{item}}">+</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="bottom-bar">
    <view class="cart-info" bindtap="toggleCart">
      <view class="cart-icon {{totalCount > 0 ? 'active' : ''}}">
        🛒 <view class="badge" wx:if="{{totalCount > 0}}">{{totalCount}}</view>
      </view>
      <view class="price-box">
        <view class="price-num">￥{{totalPrice}}</view>
        <view class="price-tips">另需配送费 ￥1</view>
      </view>
    </view>
    <view class="pay-btn {{totalPrice > 0 ? 'active' : ''}}" bindtap="goToPay">
      {{totalPrice > 0 ? '去结算' : '￥0 起送'}}
    </view>
  </view>
</view>