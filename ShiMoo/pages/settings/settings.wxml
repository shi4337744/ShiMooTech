<view class="settings-container">
  
  <view class="settings-group">
    <view class="settings-item" bindtap="goToProfile">
      <text class="item-text">编辑个人资料</text>
      <text class="item-arrow">〉</text>
    </view>
    <view class="settings-item" bindtap="clearCache">
      <text class="item-text">清除本地缓存</text>
      <text class="item-value">{{cacheSize}}</text>
    </view>
  </view>

  <view class="settings-group">
    <view class="settings-item" bindtap="showAbout">
      <text class="item-text">关于我们</text>
      <text class="item-arrow">〉</text>
    </view>
    <view class="settings-item">
      <text class="item-text">当前版本</text>
      <text class="item-value">v 1.0.0</text>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">退出登录</view>

</view>