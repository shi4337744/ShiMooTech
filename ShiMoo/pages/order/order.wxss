page { background: #f4f7fa; }
.order-page { padding: 30rpx; }
.order-header { font-size: 40rpx; font-weight: bold; color: #1e293b; margin-bottom: 30rpx; }

.order-card { background: #fff; border-radius: 32rpx; padding: 30rpx; margin-bottom: 25rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02); }
.card-top { display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f1f5f9; padding-bottom: 20rpx; }
.shop-name { font-size: 32rpx; font-weight: bold; color: #334155; }
.status { font-size: 24rpx; color: #94a3b8; }
.status.active { color: #ef4444; font-weight: bold; }

.items-preview { padding: 25rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.item-line { display: flex; justify-content: space-between; font-size: 28rpx; color: #64748b; margin-bottom: 10rpx; }

.card-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 20rpx; }
.order-time { font-size: 22rpx; color: #cbd5e1; }
.price-info { font-size: 26rpx; color: #334155; }
.price { font-size: 34rpx; font-weight: 800; color: #1e293b; }

.action-bar { display: flex; justify-content: flex-end; gap: 20rpx; margin-top: 30rpx; }
.btn { padding: 12rpx 30rpx; border-radius: 30rpx; font-size: 24rpx; font-weight: bold; }
.outline { border: 1rpx solid #e2e8f0; color: #64748b; }
.primary { background: #2563eb; color: #fff; }

.empty-box { text-align: center; padding-top: 200rpx; color: #94a3b8; }
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; opacity: 0.5; }