page { background-color: #f4f7fa; padding-bottom: 40rpx; }
.order-container { padding: 30rpx; }

/* 顶部 Tab */
.order-tabs { display: flex; background: #fff; border-radius: 20rpx; padding: 10rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02); }
.tab-item { flex: 1; text-align: center; padding: 20rpx 0; font-size: 30rpx; color: #64748b; font-weight: bold; border-radius: 15rpx; transition: all 0.2s; }
.tab-item.active { background: #eff6ff; color: #3b82f6; }

.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 150rpx 0; color: #94a3b8; }
.empty-icon { font-size: 100rpx; margin-bottom: 30rpx; opacity: 0.5; }

.order-card { background: #fff; border-radius: 24rpx; padding: 35rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); }
.order-head { display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx dashed #f1f5f9; padding-bottom: 20rpx; margin-bottom: 25rpx; }
.o-type { font-size: 24rpx; padding: 6rpx 20rpx; border-radius: 8rpx; font-weight: bold; color: #fff; }
.bg-purple { background: #8b5cf6; }
.bg-green { background: #10b981; }

.o-status { font-size: 28rpx; font-weight: bold; }
.text-gray { color: #94a3b8; }
.text-blue { color: #3b82f6; }
.text-orange { color: #f59e0b; }

.order-body { margin-bottom: 25rpx; }
.o-title { font-size: 32rpx; font-weight: bold; color: #334155; margin-bottom: 25rpx; line-height: 1.5; }

/* 敏感信息 */
.o-secret-img { width: 100%; height: 260rpx; border-radius: 16rpx; margin-bottom: 20rpx; background: #f1f5f9; }
.secret-info-box { background: #f8fafc; border-radius: 16rpx; padding: 25rpx; border: 1rpx solid #e2e8f0; margin-bottom: 25rpx; }
.s-info-item { display: flex; align-items: center; margin-bottom: 16rpx; font-size: 28rpx; color: #475569; }
.s-info-item:last-child { margin-bottom: 0; }
.s-icon { margin-right: 15rpx; font-size: 32rpx; }
.s-text { font-weight: 500; }
.phone-row { display: flex; justify-content: space-between; align-items: center; }
.call-btn { font-size: 24rpx; color: #fff; background: #3b82f6; padding: 4rpx 20rpx; border-radius: 30rpx; font-weight: bold; }

/* 价格与时间 */
.price-time-row { display: flex; justify-content: space-between; align-items: flex-end; background: #fffcf8; padding: 20rpx; border-radius: 16rpx; }
.price-label { font-size: 24rpx; color: #94a3b8; font-weight: normal; margin-right: 10rpx; }
.o-price { font-size: 40rpx; font-weight: 900; color: #ef4444; display: flex; align-items: baseline; }
.o-time { font-size: 24rpx; color: #94a3b8; }

.order-foot { display: flex; justify-content: flex-end; border-top: 1rpx solid #f1f5f9; padding-top: 25rpx; }
.o-btn { color: #fff; font-size: 28rpx; padding: 14rpx 40rpx; border-radius: 40rpx; font-weight: bold; background: #3b82f6; transition: all 0.2s; }
.o-btn:active { transform: scale(0.95); }
.o-btn.disabled { background: #cbd5e1; }
.o-btn.cancel { background: #f1f5f9; color: #64748b; }
.o-btn.confirm { background: #10b981; box-shadow: 0 4rpx 12rpx rgba(16,185,129,0.3); }

.fade-in { animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }