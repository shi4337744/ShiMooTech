<view class="order-page">
  <view class="order-header">我的订单</view>

  <view class="order-list">
    <view class="empty-box" wx:if="{{orders.length === 0}}">
      <view class="empty-icon">📂</view>
      <text>暂无相关订单记录</text>
    </view>

    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="card-top">
        <view class="shop-name">{{item.shopName}}</view>
        <view class="status {{item.status === '待配送' ? 'active' : ''}}">{{item.status}}</view>
      </view>

      <view class="items-preview">
        <view class="item-line" wx:for="{{item.items}}" wx:for-item="dish" wx:key="name">
          <text>{{dish.name}}</text>
          <text>x{{dish.count}}</text>
        </view>
      </view>

      <view class="card-bottom">
        <text class="order-time">{{item.time}}</text>
        <view class="price-info">合计 <text class="price">￥{{item.totalPrice}}</text></view>
      </view>

      <view class="action-bar" wx:if="{{item.status === '待配送'}}">
        <view class="btn outline" bindtap="cancelOrder" data-id="{{item.id}}">取消订单</view>
        <view class="btn primary">联系商家</view>
      </view>
    </view>
  </view>
</view>