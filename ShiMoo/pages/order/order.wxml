<view class="order-container">
  <view class="order-tabs">
    <view class="tab-item {{currentTab === 'published' ? 'active' : ''}}" bindtap="switchTab" data-tab="published">我发出的</view>
    <view class="tab-item {{currentTab === 'accepted' ? 'active' : ''}}" bindtap="switchTab" data-tab="accepted">我处理的</view>
  </view>

  <view class="empty-state" wx:if="{{(currentTab === 'published' && publishedOrders.length === 0) || (currentTab === 'accepted' && acceptedOrders.length === 0)}}">
    <view class="empty-icon">📦</view>
    <text>{{currentTab === 'published' ? '您还没有发布过任何跑腿或闲置' : '您还没有接取或购买过任何订单'}}</text>
  </view>

  <view class="order-list">
    <view class="order-card fade-in" wx:for="{{currentTab === 'published' ? publishedOrders : acceptedOrders}}" wx:key="id">
      
      <view class="order-head">
        <view class="o-type {{item.type === 'errand' ? 'bg-purple' : 'bg-green'}}">
          {{item.type === 'errand' ? '🏃 跑腿任务' : '📦 闲置交易'}}
        </view>
        <text class="o-status {{item.orderStatus === 'pending' ? 'text-gray' : (item.orderStatus === 'processing' ? 'text-blue' : 'text-orange')}}">
          {{item.orderStatus === 'pending' ? (item.type === 'errand' ? '等待接单' : '等待买家') : ''}}
          {{item.orderStatus === 'processing' ? (item.type === 'errand' ? '配送中' : '交易进行中') : ''}}
          {{item.orderStatus === 'delivered' ? '已送达，待收货' : ''}}
        </text>
      </view>

      <view class="order-body">
        <view class="o-title">{{item.content}}</view>

        <block wx:if="{{currentTab === 'accepted' && item.type === 'errand'}}">
          <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" class="o-secret-img" mode="aspectFill" bindtap="previewImage" data-url="{{item.imageUrl}}"></image>
          <view class="secret-info-box">
            <view class="s-info-item"><text class="s-icon">📍</text><text class="s-text">送至：{{item.location}}</text></view>
            <view class="s-info-item"><text class="s-icon">⏰</text><text class="s-text">要求：限 {{item.deadline}} 前</text></view>
            <view class="s-info-item phone-row" bindtap="callPhone" data-phone="{{item.phone}}">
              <view><text class="s-icon">📱</text><text class="s-text">电话：{{item.phone || '未留电话'}}</text></view>
              <text class="call-btn" wx:if="{{item.phone}}">拨打</text>
            </view>
          </view>
        </block>

        <view class="price-time-row">
          <view class="o-price">
            <text class="price-label">{{item.type === 'errand' ? '悬赏' : '售价'}}</text>
            ￥{{item.price}}
          </view>
          <view class="o-time">{{currentTab === 'published' ? '发布于' : '接单于'}}：{{item.time}}</view>
        </view>
      </view>

      <view class="order-foot">
        
        <block wx:if="{{currentTab === 'accepted' && item.orderStatus === 'processing'}}">
          <view class="o-btn" bindtap="deliverOrder" data-id="{{item.id}}">
            {{item.type === 'errand' ? '确认送达' : '确认已发货/交付'}}
          </view>
        </block>
        <block wx:if="{{currentTab === 'accepted' && item.orderStatus === 'delivered'}}">
          <view class="o-btn disabled">等待对方确认收货</view>
        </block>

        <block wx:if="{{currentTab === 'published' && item.orderStatus === 'pending'}}">
          <view class="o-btn cancel" bindtap="cancelPublished" data-id="{{item.id}}">取消发布</view>
        </block>
        <block wx:if="{{currentTab === 'published' && item.orderStatus === 'delivered'}}">
          <view class="o-btn confirm" bindtap="confirmReceipt" data-id="{{item.id}}">确认收货</view>
        </block>

      </view>

    </view>
  </view>
</view>