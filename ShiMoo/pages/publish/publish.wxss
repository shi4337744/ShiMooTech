page { background-color: #f8fafc; padding-bottom: 150rpx; }
.publish-container { padding: 30rpx; }

/* 输入框卡片 */
.input-card { background: #fff; border-radius: 24rpx; padding: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02); position: relative; }
.content-textarea { width: 100%; height: 280rpx; font-size: 30rpx; color: #1e293b; line-height: 1.6; }
.word-count { text-align: right; font-size: 24rpx; color: #cbd5e1; margin-top: 20rpx; }

/* 图片上传区 */
.section-title { font-size: 28rpx; font-weight: bold; color: #64748b; margin: 40rpx 0 20rpx 10rpx; }
.image-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.media-item { position: relative; width: 210rpx; height: 210rpx; }
.preview-img { width: 100%; height: 100%; border-radius: 20rpx; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1); }
.del-img { position: absolute; top: -15rpx; right: -15rpx; width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.6); color: #fff; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 30rpx; z-index: 10;}
.add-btn { width: 210rpx; height: 210rpx; background: #fff; border: 2rpx dashed #cbd5e1; border-radius: 20rpx; display: flex; flex-direction: column; justify-content: center; align-items: center; }
.plus { font-size: 50rpx; color: #94a3b8; }
.add-txt { font-size: 24rpx; color: #94a3b8; margin-top: 10rpx; }

/* 选项组 */
.option-group { margin-top: 40rpx; background: #fff; border-radius: 24rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02); }
.option-item { display: flex; justify-content: space-between; align-items: center; padding: 35rpx 30rpx; border-bottom: 1rpx solid #f8fafc; }
.option-item:last-child { border-bottom: none; }
.disabled-item { opacity: 0.6; background-color: #f8fafc; } /* 编辑模式下的灰化 */

.flex-col-item { flex-direction: column; align-items: flex-start; }
.item-left { display: flex; align-items: center; }
.full-width { width: 100%; margin-bottom: 25rpx; }
.item-icon { font-size: 36rpx; margin-right: 20rpx; }
.item-label { font-size: 30rpx; color: #334155; font-weight: 500; }
.sub-label { font-size: 24rpx; color: #94a3b8; font-weight: normal; margin-left: 10rpx; }
.item-value { font-size: 28rpx; color: #94a3b8; margin-right: 10rpx; }
.arrow { color: #cbd5e1; font-size: 24rpx; }

/* ===== 各种输入框文字高亮辅助 ===== */
.flex-1 { flex: 1; }
.ml-20 { margin-left: 20rpx; }
.right-align { text-align: right; width: 100%; font-size: 28rpx; color: #1e293b; }
.channel-value { color: #2563eb; font-weight: bold; }
.tag-input { color: #3b82f6; font-weight: bold; }
.price-input { color: #f59e0b; font-weight: bold; font-size: 32rpx;}
.price-red { color: #ef4444; font-weight: bold; font-size: 32rpx;}

/* 多选标签样式 */
.tags-container { display: flex; flex-wrap: wrap; gap: 20rpx; width: 100%; }
.tag-pill { background: #f1f5f9; color: #64748b; font-size: 26rpx; padding: 12rpx 26rpx; border-radius: 30rpx; border: 2rpx solid transparent; transition: all 0.2s; }
.tag-pill.active { background: #eff6ff; color: #3b82f6; border-color: #3b82f6; font-weight: bold; }

/* 底部发布栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 40rpx; padding-bottom: env(safe-area-inset-bottom); border-top: 1rpx solid #f1f5f9; z-index: 100; }
.submit-btn { background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; height: 90rpx; border-radius: 45rpx; display: flex; justify-content: center; align-items: center; font-size: 32rpx; font-weight: bold; box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.2); }
.btn-active { transform: scale(0.98); opacity: 0.9; }