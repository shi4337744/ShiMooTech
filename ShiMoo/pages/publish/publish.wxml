<view class="publish-container">
  <view class="input-card">
    <textarea 
      class="content-textarea" 
      placeholder="详细描述你的需求..." 
      maxlength="500"
      bindinput="onInput"
    ></textarea>
  </view>

  <block wx:if="{{channelIndex == 0}}">
    <view class="section-title">添加图片</view>
    <view class="image-grid">
      <view class="add-btn" bindtap="chooseImage">
        <text class="plus">+</text>
        <text class="add-txt">上传照片</text>
      </view>
    </view>
  </block>

  <view class="section-title">发布设置</view>
  <view class="option-group">
    
    <picker mode="selector" range="{{channels}}" bindchange="onChannelChange">
      <view class="option-item">
        <view class="item-left">
          <text class="item-icon">🏷️</text>
          <text class="item-label">发布频道</text>
        </view>
        <view class="item-right">
          <text class="item-value" style="color: #2563eb; font-weight: bold;">{{channels[channelIndex]}}</text>
          <text class="arrow">〉</text>
        </view>
      </view>
    </picker>

    <view class="option-item">
      <view class="item-left">
        <text class="item-icon">📍</text>
        <text class="item-label">详细位置</text>
      </view>
      <view class="item-right" style="flex: 1; margin-left: 20rpx;">
        <input class="input-field" placeholder="例:11号楼302 (可选)" bindinput="onLocationInput" style="text-align: right;"/>
      </view>
    </view>

    <block wx:if="{{channelIndex == 0}}">
      <view class="option-item">
        <view class="item-left">
          <text class="item-icon">#️⃣</text>
          <text class="item-label">自定义标签</text>
        </view>
        <view class="item-right">
          <input class="input-field" placeholder="#例:寻物启事#" bindinput="onTagInput" style="text-align: right; color:#3b82f6; font-weight:bold;"/>
        </view>
      </view>
    </block>

    <block wx:if="{{channelIndex == 1}}">
      <view class="option-item">
        <view class="item-left">
          <text class="item-icon">💰</text>
          <text class="item-label">悬赏金额(元)</text>
        </view>
        <view class="item-right">
          <input class="input-field" type="digit" placeholder="0.00" bindinput="onPriceInput" style="text-align: right; color:#f59e0b; font-weight:bold;"/>
        </view>
      </view>
      <picker mode="time" bindchange="onTimeChange">
        <view class="option-item">
          <view class="item-left">
            <text class="item-icon">⏰</text>
            <text class="item-label">要求送达时间</text>
          </view>
          <view class="item-right">
            <text class="item-value">{{deadline || '点击设置'}}</text>
            <text class="arrow">〉</text>
          </view>
        </view>
      </picker>
    </block>

    <block wx:if="{{channelIndex == 2}}">
      <picker mode="selector" range="{{marketTypes}}" bindchange="onMarketTypeChange">
        <view class="option-item">
          <view class="item-left">
            <text class="item-icon">🔄</text>
            <text class="item-label">交易类型</text>
          </view>
          <view class="item-right">
            <text class="item-value">{{marketTypes[marketTypeIndex]}}</text>
            <text class="arrow">〉</text>
          </view>
        </view>
      </picker>
      <view class="option-item">
        <view class="item-left">
          <text class="item-icon">💵</text>
          <text class="item-label">期望价格</text>
        </view>
        <view class="item-right">
          <input class="input-field" type="digit" placeholder="请输入金额" bindinput="onPriceInput" style="text-align: right; color:#ef4444; font-weight:bold;"/>
        </view>
      </view>
    </block>

  </view>

  <view class="bottom-bar">
    <button class="submit-btn" bindtap="submitPost">立即发布</button>
  </view>
</view>